{
  "manifest_version": 2,
  "version": "0.1",
  "name": "Ritual",
  "homepage_url": "https://github.com/roosta/ritual-firefox-theme",
  "browser_specific_settings": {
    "gecko": {
      "id": "ritual@roosta.sh"
    }
  },
  "theme": {
    "properties": {
      "color_scheme": "dark"
    },
    "colors": {
      "bookmark_text": "#FCE8C3",
      "button_background_active": "#504D47",
      "button_background_hover": "#312F2C",
      "frame": "#121110",
      "icons_attention": "#E02C6D",
      "ntp_background": "#262522",
      "ntp_card_background": "#1C1B19",
      "ntp_text": "#FCE8C3",
      "popup": "#1C1B19",
      "popup_border": "#312F2C",
      "popup_highlight_text": "#FCE8C3",
      "popup_text": "#FCE8C3",
      "sidebar": "#1C1B19",
      "sidebar_border": "#312F2C",
      "sidebar_highlight": "#1E5181",
      "sidebar_highlight_text": "#FCE8C3",
      "sidebar_text": "#FCE8C3",
      "tab_background_separator": "#312F2C",
      "tab_background_text": "#C5B088",
      "tab_line": "#312F2C",
      "tab_selected": "#1C1B19",
      "toolbar": "#1C1B19",
      "toolbar_bottom_separator": "#312F2C",
      "toolbar_field": "#0E0D0C",
      "toolbar_field_border": "#262522",
      "toolbar_field_border_focus": "#1E5181",
      "toolbar_field_focus": "#0E0D0C",
      "toolbar_field_highlight": "#1E5181",
      "toolbar_field_highlight_text": "#FCE8C3",
      "toolbar_field_text": "#FCE8C3",
      "toolbar_field_text_focus": "#FCE8C3",
      "toolbar_text": "#FCE8C3",
      "toolbar_top_separator": "#312F2C",
      "toolbar_vertical_separator": "#312F2C"
    }
  }
}
